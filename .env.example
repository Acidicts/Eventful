# Copy this file to .env and populate with real values.
# These values are used by OmniAuth/Hack Club integration.
HACKCLUB_CLIENT_ID=your_client_id
HACKCLUB_CLIENT_SECRET=your_client_secret

# host that OmniAuth should advertise for callback URLs in development.
# Should match the value registered with Hack Club (e.g. http://localhost:3000
# or http://dev.bing-bong.uk:3000).
#OMNIAUTH_FULL_HOST=http://localhost:3000

# Scopes to request from Hack Club.
# Currently supported (per /.well-known/openid-configuration): openid profile phone birthdate
# Future/desired scopes (enable when the provider adds them):
#   email offline_access slack_id verification_status
# Space-separated; do NOT use commas.
#HACKCLUB_OAUTH_SCOPES="openid profile"
