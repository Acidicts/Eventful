<h1>
  <% if @organisation %>
    Events for <%= @organisation.id %>
  <% else %>
    All Events
  <% end %>
</h1>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Name</th>
      <th>Description</th>
      <th>Capacity</th>
      <th>Applied</th>
      <th>Attendee</th>
      <% if @organisation %>
        <th colspan="3"></th>
      <% end %>
    </tr>
  </thead>

  <tbody>
    <% @events.each do |event| %>
      <tr>
        <% if @organisation %>
          <td><%= link_to event.id, [@organisation, event] %></td>
        <% else %>
          <td><%= event.id %></td>
        <% end %>
        <td><%= event.name %></td>
        <td><%= event.description %></td>
        <td><%= event.capacity %></td>
        <td><%= event.applied %></td>
        <td><%= event.attendee_id %></td>
        <% if @organisation %>
          <td><%= link_to 'Edit', edit_organisation_event_path(@organisation, event) %></td>
          <td><%= link_to 'Destroy', [@organisation, event], method: :delete, data: { confirm: 'Are you sure?' } %></td>
        <% end %>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @organisation %>
  <%= link_to 'New Event', new_organisation_event_path(@organisation) %> |
  <%= link_to 'Back to Organisation', organisation_path(@organisation) %>
<% end %>
