<h1>Organisations</h1>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>User</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @organisations.each do |org| %>
      <tr>
        <td><%= link_to org.id, org %></td>
        <td><%= org.user_id %></td>
        <td><%= link_to 'Edit', edit_organisation_path(org) %></td>
        <td><%= link_to 'Destroy', org, method: :delete, data: { confirm: 'Are you sure?' } %></td>
        <td><%= link_to 'Events', organisation_events_path(org) %></td>
      </tr>
    <% end %>
  </tbody>
</table>

